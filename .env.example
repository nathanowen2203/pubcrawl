# Copy this file to .env.local and paste your key in.
# Create a key at https://console.cloud.google.com
# Enable these APIs: Maps JavaScript API, Directions API, Places API (New)
VITE_GOOGLE_MAPS_API_KEY=

# Optional. A Map ID from Cloud Console (Map Management).
# DEMO_MAP_ID works fine for personal use.
VITE_GOOGLE_MAPS_MAP_ID=DEMO_MAP_ID

# --- Optional: real-time sync across devices via Firebase ---
# If left blank, the app falls back to per-browser localStorage.
# Create a Firebase project at https://console.firebase.google.com,
# enable Realtime Database, then copy these from your web app config.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
